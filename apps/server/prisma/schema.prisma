datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  USER
}

enum ProductStatus {
  DISPONIBLE
  AGOTADO
  BAJO_STOCK
}

enum ProductUnit {
  UNIDAD
  KG
  GRAMOS
  PAQUETE
  LITRO
  CAJA
}

enum Area {
  COCINA
  BARRA
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // Hashed con bcrypt
  name      String
  role      Role     @default(USER)
  area      Area?    // null = ADMIN (ve todo); requerido en la práctica para USER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Supplier {
  id        String    @id @default(uuid())
  name      String    @unique
  email     String?
  phone     String?
  notes     String?
  website   String?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("suppliers")
}

model Product {
  id           String        @id @default(uuid())
  name         String        @unique
  status       ProductStatus @default(DISPONIBLE)
  unit         ProductUnit   @default(UNIDAD)
  stock        Int           @default(0)
  minQuantity  Int           @default(1)
  maxQuantity  Int           @default(10)
  durationDays Int?
  imageUrl     String?
  notes        String?
  isFavorite   Boolean       @default(false)
  area         Area?         // null = visible para cocina y barra
  reportedAt   DateTime?     // null = disponible para reportar; con fecha = ya reportado, bloqueado

  // Relación Opcional con Proveedor
  supplierId   String?
  supplier     Supplier?     @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("products")
}

model ChecklistReport {
  id          String   @id @default(uuid())
  submittedBy String
  items       Json     // Instantánea del reporte en formato JSON
  createdAt   DateTime @default(now())

  @@map("checklist_reports")
}
